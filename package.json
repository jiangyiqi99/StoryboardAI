{
  "name": "storyboard-ai-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An AI-generated GPLv3 desktop video editor scaffold with AI workflows, built with Electron, React, TypeScript, and FFmpeg.",
  "author": "StoryboardAI",
  "engines": {
    "node": ">=24"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "npm run native:libav && npm run build && electron-builder --publish never",
    "dist:macarm64": "npm run native:libav && npm run build && electron-builder --mac --arm64 --publish never",
    "dist:macx64": "npm run native:libav && npm run build && electron-builder --mac --x64 --publish never",
    "dist:win": "npm run native:libav && npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run native:libav && npm run build && electron-builder --linux --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "native:libav": "node native/libav/scripts/build.mjs"
  },
  "build": {
    "appId": "ai.storyboard.editor",
    "productName": "Storyboard AI Editor",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json",
      "LICENSE"
    ],
    "extraResources": [
      {
        "from": "native/libav/bin",
        "to": "native/libav/bin"
      },
      {
        "from": "native/libav/runtime",
        "to": "native/libav/runtime"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "category": "AudioVideo",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
